# Tip: set MULTIPLE keys separated by commas to rotate and multiply free
# quota, e.g. GROQ_API_KEY=key1,key2,key3
GROQ_API_KEY=
GEMINI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
WP_URL=
WP_USERNAME=
WP_APP_PASSWORD=

# Optional model overrides. Defaults are current production models, so you can
# leave these blank. Set them when Groq/Gemini rotate models again.
# Groq large (default: openai/gpt-oss-120b)
GROQ_MODEL=
# Groq fast (default: openai/gpt-oss-20b)
GROQ_FAST_MODEL=
# Gemini (default: gemini-flash-latest)
GEMINI_MODEL=

# Optional: brand voice/tone injected into article generation
# e.g. "santai tapi kredibel, sapa pembaca dengan 'kamu'"
BRAND_VOICE=

# Blogger / Google OAuth (see docs/blogger-setup.md for how to obtain these)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
BLOGGER_BLOG_ID=your_blogger_blog_id

# Cron
# Random secret to authorize scheduled cron requests.
# Example: wlytics_cron_secret_2026_xK9mP3qR7vN (buat string random sendiri)
CRON_SECRET=your_random_secret_string
# Same value as CRON_SECRET, exposed to the client for the manual
# "Jalankan Sekarang" trigger button (note: visible in the browser).
NEXT_PUBLIC_CRON_SECRET=same_value_as_CRON_SECRET
