# Optional model overrides. Defaults are current production models, so you can
# leave these blank. Set them when Groq/Gemini rotate models again.
# Groq large (default: openai/gpt-oss-120b)
GROQ_MODEL=
# Groq fast (default: openai/gpt-oss-20b)
GROQ_FAST_MODEL=
# Gemini (default: gemini-flash-latest)
GEMINI_MODEL=
